{
  "name": "vscode-tieba",
  "displayName": "Tieba Fish",
  "description": "在 VS Code 里低打扰地看百度贴吧。",
  "version": "0.0.1",
  "publisher": "local",
  "license": "UNLICENSED",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "icon": "resources/tieba.svg",
  "main": "./out/extension.js",
  "activationEvents": [
    "onView:tieba.forums",
    "onView:tieba.latest",
    "onView:tieba.history",
    "onCommand:tieba.addForum",
    "onCommand:tieba.configureAccount",
    "onCommand:tieba.clearAccount",
    "onCommand:tieba.configureCookie",
    "onCommand:tieba.clearCookie",
    "onCommand:tieba.bossKey",
    "onCommand:tieba.openThreadByUrl",
    "onCommand:tieba.openForum",
    "onCommand:tieba.openThread"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "tieba",
          "title": "Tieba",
          "icon": "resources/tieba.svg"
        }
      ]
    },
    "views": {
      "tieba": [
        {
          "id": "tieba.forums",
          "name": "关注吧",
          "when": "!tieba.bossModeEnabled"
        },
        {
          "id": "tieba.latest",
          "name": "最新",
          "when": "!tieba.bossModeEnabled"
        },
        {
          "id": "tieba.history",
          "name": "历史",
          "when": "!tieba.bossModeEnabled"
        },
        {
          "id": "tieba.bossFiles",
          "name": "资源管理器",
          "when": "tieba.bossModeEnabled"
        }
      ]
    },
    "commands": [
      {
        "command": "tieba.addForum",
        "title": "Tieba: 添加贴吧",
        "category": "Tieba"
      },
      {
        "command": "tieba.refreshAll",
        "title": "Tieba: 刷新视图",
        "category": "Tieba"
      },
      {
        "command": "tieba.refreshLatest",
        "title": "Tieba: 刷新",
        "category": "Tieba"
      },
      {
        "command": "tieba.latestPreviousPage",
        "title": "Tieba: 最新数据上一页",
        "category": "Tieba"
      },
      {
        "command": "tieba.latestNextPage",
        "title": "Tieba: 最新数据下一页",
        "category": "Tieba"
      },
      {
        "command": "tieba.configureAccount",
        "title": "Tieba: 配置贴吧账号 (BDUSS/STOKEN)",
        "category": "Tieba"
      },
      {
        "command": "tieba.clearAccount",
        "title": "Tieba: 清除贴吧账号",
        "category": "Tieba"
      },
      {
        "command": "tieba.configureCookie",
        "title": "Tieba: 配置贴吧 Cookie",
        "category": "Tieba"
      },
      {
        "command": "tieba.clearCookie",
        "title": "Tieba: 清除贴吧 Cookie",
        "category": "Tieba"
      },
      {
        "command": "tieba.openForum",
        "title": "Tieba: 打开贴吧",
        "category": "Tieba"
      },
      {
        "command": "tieba.removeForum",
        "title": "Tieba: 移除贴吧",
        "category": "Tieba"
      },
      {
        "command": "tieba.openThread",
        "title": "Tieba: 打开帖子",
        "category": "Tieba"
      },
      {
        "command": "tieba.openThreadByUrl",
        "title": "Tieba: 浏览指定链接",
        "category": "Tieba"
      },
      {
        "command": "tieba.openExternal",
        "title": "Tieba: 在浏览器打开",
        "category": "Tieba"
      },
      {
        "command": "tieba.openInSimpleBrowser",
        "title": "Tieba: 在 VS Code 浏览器打开",
        "category": "Tieba"
      },
      {
        "command": "tieba.toggleImages",
        "title": "Tieba: 切换图片显示",
        "category": "Tieba"
      },
      {
        "command": "tieba.bossKey",
        "title": "Tieba: 老板键",
        "category": "Tieba"
      }
    ],
    "keybindings": [
      {
        "command": "tieba.bossKey",
        "key": "ctrl+alt+x",
        "mac": "cmd+alt+x",
        "when": "editorTextFocus || webviewFocus || sideBarFocus || listFocus || !inputFocus"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "tieba.addForum",
          "when": "view == tieba.forums",
          "group": "navigation@1"
        },
        {
          "command": "tieba.refreshAll",
          "when": "view == tieba.forums || view == tieba.history",
          "group": "navigation@2"
        },
        {
          "command": "tieba.refreshLatest",
          "when": "view == tieba.latest",
          "group": "navigation@3"
        },
        {
          "command": "tieba.openThreadByUrl",
          "when": "view == tieba.forums",
          "group": "secondary@1"
        }
      ],
      "view/item/context": [
        {
          "command": "tieba.removeForum",
          "when": "view == tieba.forums && viewItem == tieba.forum",
          "group": "inline"
        }
      ],
      "commandPalette": [
        {
          "command": "tieba.configureAccount",
          "when": "true"
        },
        {
          "command": "tieba.clearAccount",
          "when": "true"
        },
        {
          "command": "tieba.addForum",
          "when": "true"
        },
        {
          "command": "tieba.openThreadByUrl",
          "when": "true"
        },
        {
          "command": "tieba.configureCookie",
          "when": "true"
        },
        {
          "command": "tieba.clearCookie",
          "when": "true"
        },
        {
          "command": "tieba.bossKey",
          "when": "true"
        },
        {
          "command": "tieba.toggleImages",
          "when": "true"
        }
      ]
    },
    "configuration": {
      "title": "Tieba",
      "properties": {
        "tieba.showImages": {
          "type": "boolean",
          "default": true,
          "description": "是否在帖子阅读页显示图片。"
        },
        "tieba.compactMode": {
          "type": "boolean",
          "default": false,
          "description": "是否启用紧凑阅读模式。"
        },
        "tieba.lowContrastMode": {
          "type": "boolean",
          "default": true,
          "description": "是否降低阅读页的视觉存在感。"
        },
        "tieba.cacheMinutes": {
          "type": "number",
          "default": 3,
          "minimum": 0,
          "description": "贴吧列表缓存分钟数。设为 0 表示不缓存。"
        },
        "tieba.maxHistory": {
          "type": "number",
          "default": 100,
          "minimum": 10,
          "description": "历史记录最大条数。"
        },
        "tieba.openThreadMode": {
          "type": "string",
          "enum": [
            "active",
            "beside"
          ],
          "default": "active",
          "description": "打开帖子时是在当前分组还是旁边分组。"
        },
        "tieba.fallbackToBrowser": {
          "type": "boolean",
          "default": true,
          "description": "抓取失败时，界面中展示在浏览器里打开的回退入口。"
        },
        "tieba.pythonPath": {
          "type": "string",
          "default": "python",
          "description": "运行 aiotieba bridge 时使用的 Python 可执行文件。例如 python、py 或绝对路径。"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "dependencies": {
    "cheerio": "^1.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.16.11",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.6.3"
  }
}
